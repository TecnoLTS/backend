ENTORNO_MODE=qa
DB_HOST=db
DB_PORT=5432
## El GUC tenant RLS es de sesion: usar direct o PgBouncer session pooling.
## transaction/statement pooling se rechazan en TENANT_RLS_MODE=enforce.
DB_POOL_MODE=direct
# Production HA usa session + verify-full y monta la CA dentro del runtime.
DB_SSLMODE=prefer
DB_SSLROOTCERT=
DB_DATABASE=ecommerce
DB_USERNAME=paramascotasec_backend_app
DB_PASSWORD=change-this-to-a-strong-password
# RLS fail-closed. API, platform-auth, workers, FDW y owner son roles distintos.
TENANT_RLS_MODE=enforce
DB_OWNER_ROLE=paramascotasec_backend_owner
# NOLOGIN/BYPASSRLS, sin password ni membresias; solo posee funciones auth tipadas.
DB_PLATFORM_AUTH_ROLE=paramascotasec_backend_platform_auth
## Rol transversal solo para auditorias one-shot; no se inyecta en runtimes.
DB_WORKER_USERNAME=paramascotasec_backend_audit_worker
DB_WORKER_PASSWORD=change-this-to-an-independent-audit-password
## Workers runtime separados por dominio y sin CONNECT cruzado.
DB_WORKER_USERNAME_COMMERCE=paramascotasec_backend_commerce_billing_worker
DB_WORKER_PASSWORD_COMMERCE=change-this-to-an-independent-commerce-worker-password
DB_WORKER_USERNAME_BILLING=paramascotasec_backend_billing_worker
DB_WORKER_PASSWORD_BILLING=change-this-to-an-independent-billing-worker-password
DB_WORKER_USERNAME_LOYALTY_REWARDS=paramascotasec_backend_loyalty_worker
DB_WORKER_PASSWORD_LOYALTY_REWARDS=change-this-to-an-independent-loyalty-worker-password
DB_WORKER_USERNAME_IDENTITY_PLATFORM=paramascotasec_backend_identity_platform_worker
DB_WORKER_PASSWORD_IDENTITY_PLATFORM=change-this-to-an-independent-identity-worker-password
DB_WORKER_USERNAME_MAILER_SERVICE=paramascotasec_backend_mailer_worker
DB_WORKER_PASSWORD_MAILER_SERVICE=change-this-to-an-independent-mailer-worker-password
DB_FDW_USERNAME=paramascotasec_backend_fdw
DB_FDW_PASSWORD=change-this-to-another-independent-strong-password
DB_DATABASE_IDENTITY_PLATFORM=dashboard
DB_DATABASE_CATALOG_INVENTORY=ecommerce
DB_DATABASE_COMMERCE=ecommerce
DB_DATABASE_REPORTING_FINANCE=ecommerce
DB_DATABASE_BILLING=facturacion
DB_USERNAME_BILLING=paramascotasec_backend_app
DB_PASSWORD_BILLING=change-this-to-a-strong-password
# Solo para migrar Image/Variation/OrderItem legacy cuyo padre ya no existe.
# Dejar vacio salvo validacion manual previa.
ECOMMERCE_LEGACY_TENANT_ID=
# Solo para migrar clientes/API keys fiscales legacy sin factura u orden que
# permita derivar ownership. Dejar vacio salvo validacion manual previa.
BILLING_LEGACY_TENANT_ID=
DB_DATABASE_MAILER_SERVICE=dashboard

# Outbox Mailer durable: send/sendHtml solo aceptan en DB; SMTP corre aqui.
MAILER_OUTBOX_INTERVAL_SECONDS=10
MAILER_OUTBOX_BATCH_SIZE=100
MAILER_OUTBOX_PER_TENANT=10
MAILER_OUTBOX_LEASE_SECONDS=120
MAILER_OUTBOX_MAX_SECONDS=50
MAILER_OUTBOX_MAX_ATTEMPTS=8
MAILER_OUTBOX_RETRY_BASE_SECONDS=15
MAILER_OUTBOX_RETRY_MAX_SECONDS=1800
MAILER_OUTBOX_RETRY_JITTER_PERCENT=20
MAILER_OUTBOX_MESSAGE_TTL_SECONDS=3600
MAILER_OUTBOX_MAX_BODY_BYTES=262144
MAILER_OUTBOX_HEALTH_MAX_DUE_AGE_SECONDS=300
# Umbral de degradacion/SLO por DLQ no resuelta; no convierte una incidencia
# de negocio aislada en fallo de disponibilidad del runtime.
MAILER_OUTBOX_HEALTH_MAX_DEAD_LETTER=0

DEFAULT_TENANT=paramascotasec
PUBLIC_TENANT_SLUG=paramascotasec
PUBLIC_LOYALTY_SERVICE_SEGMENT=fidelizacion
PUBLIC_SCHEME=https
PRIMARY_SITE_DOMAIN=paramascotasec.com
PRIMARY_SITE_ALIASES=www.paramascotasec.com
DASHBOARD_ADMIN_HOST=admin.paramascotasec.com
PUBLIC_BASE_URL=https://paramascotasec.com
TENANT_DISPLAY_NAME="Para Mascotas EC"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_SECRET_PREVIOUS=
EDGE_BACKEND_PROXY_TOKEN=replace-with-dedicated-edge-backend-proxy-token
EDGE_BACKEND_PROXY_TOKEN_PREVIOUS=
STOREFRONT_BACKEND_PROXY_TOKEN=replace-with-dedicated-storefront-backend-proxy-token
STOREFRONT_BACKEND_PROXY_TOKEN_PREVIOUS=
TENANT_RUNTIME_REGISTRY_SNAPSHOT_SECRET=replace-with-an-independent-64-character-secret
TENANT_RUNTIME_REGISTRY_SNAPSHOT_PATH=/var/www/html/storage/runtime/tenant-registry.snapshot.json
TENANT_RUNTIME_REGISTRY_SNAPSHOT_MAX_AGE_SECONDS=86400
AUTH_COOKIE_NAME=pm_auth
AUTH_CSRF_COOKIE_NAME=pm_csrf
# Compatibilidad temporal con cookies/surface legacy. Mantener apagada salvo
# migracion controlada y retirarla despues de expirar las sesiones antiguas.
AUTH_LEGACY_COOKIE_FALLBACK_ENABLED=false
AUTH_LEGACY_SURFACE_QUERY_ENABLED=false
AUTH_COOKIE_TTL_SECONDS=10800
AUTH_COOKIE_SECURE=auto
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCK_MINUTES=15
# off | private | custom
# Use private when admins connect from LAN/VPN. Use custom for static public IPs.
ADMIN_IP_MODE=private
ADMIN_IP_ALLOWLIST=
# Production only trusts forwarded headers when the proxy also sends a valid
# X-Internal-Proxy-Token matching INTERNAL_PROXY_TOKEN.
TRUST_PROXY_HEADERS=false
SERVICE_TOKEN_TTL=86400

APP_ENV=qa
APP_URL=https://paramascotasec.com
LOG_CHANNEL=stderr
LOG_LEVEL=info

GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SA_PATH=/var/www/html/storage/wallet/service-account.json

MAIL_FROM_ADDRESS=no-reply@paramascotasec.com
MAIL_FROM_NAME="Para Mascotas EC"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls
ADMIN_MFA_FALLBACK_EMAIL=

BILLING_GATEWAY_DRIVER=native
# QA genera este keyring al primer deploy. Compose lo prepara dentro de un
# directorio 0700 como owner:GID-runtime 0440 y valida la lectura con UID/GID
# 82 antes del cutover. Produccion debe montar el archivo desde su gestor de
# secretos/KMS-compatible; nunca guardar claves maestras en variables.
BILLING_SECRET_KEYRING_HOST_PATH=./entorno/.secrets/billing-secret-keyring.json
# Compatibilidad exclusiva de la primera adopcion. Etapa A usa true+legacy
# hasta que el 100% de pods ejecute la imagen dual-read; etapa B usa
# true+encrypted antes del backfill. El gate V002 exige false+encrypted.
BILLING_SECRET_LEGACY_READ_ENABLED=false
BILLING_SECRET_WRITE_MODE=encrypted
# Native Billing uses BILLING_API_KEY; legacy FACTURADOR_API_KEY remains accepted only as a compatibility fallback.
BILLING_API_KEY=

DOMPDF_REMOTE_ENABLED=false

# Capacidad PHP-FPM. Ajustar con una prueba de carga y memoria medida por
# proceso; no aumentar max_children sin revisar BACKEND_API_MEMORY_LIMIT.
PHP_FPM_MAX_CHILDREN=16
PHP_FPM_START_SERVERS=12
PHP_FPM_MIN_SPARE_SERVERS=12
PHP_FPM_MAX_SPARE_SERVERS=14
PHP_FPM_MAX_REQUESTS=500
PHP_FPM_REQUEST_TERMINATE_TIMEOUT=120s
PHP_FPM_SLOW_REQUEST_TIMEOUT=5s
PHP_MEMORY_LIMIT=128M

# Workers periodicos y su margen de salud. El healthcheck exige al menos un
# ciclo exitoso y falla si el ultimo ciclo termino con error.
BILLING_RECOVERY_SWEEP_BATCH_SIZE=50
BILLING_RECOVERY_SWEEP_MIN_AGE_SECONDS=3600
BILLING_RECOVERY_SWEEP_INTERVAL_SECONDS=3600
BILLING_WORKER_HEALTH_GRACE_SECONDS=900
BILLING_WORKER_FAILURE_RETRY_SECONDS=60
# Outbox durable Commerce -> Billing. El worker solo lee ecommerce y llama la
# API Billing interna autenticada; nunca recibe credenciales de facturacion DB.
# Un JSON secreto versionado selecciona una credencial distinta por tenant y
# host exacto. En QA, el deploy migra una sola vez BILLING_API_KEY al registro;
# produccion debe provisionarlo desde ExternalSecret/CSI antes del despliegue.
BILLING_OUTBOX_CREDENTIALS_HOST_PATH=./entorno/.secrets/commerce-billing-credentials.json
BILLING_OUTBOX_MAX_ATTEMPTS=12
BILLING_OUTBOX_BATCH_SIZE=50
BILLING_OUTBOX_PER_TENANT=5
BILLING_OUTBOX_INTERVAL_SECONDS=10
BILLING_OUTBOX_LEASE_SECONDS=300
BILLING_OUTBOX_MAX_SECONDS=240
BILLING_OUTBOX_HTTP_TIMEOUT_SECONDS=45
BILLING_OUTBOX_RETRY_BASE_SECONDS=15
BILLING_OUTBOX_RETRY_MAX_SECONDS=3600
BILLING_OUTBOX_HEALTH_MAX_DUE_AGE_SECONDS=7200
BILLING_OUTBOX_WORKER_HEALTH_GRACE_SECONDS=60
BILLING_OUTBOX_WORKER_FAILURE_RETRY_SECONDS=15
WALLET_NOTIFY_BATCH_SIZE=100
WALLET_NOTIFY_INTERVAL_SECONDS=900
WALLET_NOTIFY_MAX_SECONDS=240
LOYALTY_WALLET_NOTIFY_THROTTLE_MS=250
WALLET_WORKER_HEALTH_GRACE_SECONDS=300
WALLET_WORKER_FAILURE_RETRY_SECONDS=60

# Presupuestos por contenedor. Son limites Compose locales, no autoscaling.
BACKEND_API_CPUS=2.0
BACKEND_API_MEMORY_LIMIT=3g
BACKEND_API_MEMORY_RESERVATION=768m
BACKEND_API_PIDS_LIMIT=256
BILLING_WORKER_CPUS=0.75
BILLING_WORKER_MEMORY_LIMIT=512m
BILLING_WORKER_MEMORY_RESERVATION=128m
BILLING_WORKER_PIDS_LIMIT=96
WALLET_WORKER_CPUS=0.75
WALLET_WORKER_MEMORY_LIMIT=512m
WALLET_WORKER_MEMORY_RESERVATION=128m
WALLET_WORKER_PIDS_LIMIT=96
BACKEND_HTTP_CPUS=0.75
BACKEND_HTTP_MEMORY_LIMIT=256m
BACKEND_HTTP_MEMORY_RESERVATION=64m
BACKEND_HTTP_PIDS_LIMIT=128

# Puede apuntar a mounts compartidos administrados por el operador. Para mas
# de una replica/host, ambos paths deben ser almacenamiento compartido; estos
# valores locales no vuelven stateless al backend por si solos.
BACKEND_STORAGE_PATH=./storage
BACKEND_UPLOADS_PATH=./public/uploads

# QA usa filesystem local. En production, si STORAGE_DRIVER queda vacio, el
# backend selecciona s3. REQUIRE_HA=true siempre rechaza local en preflight.
STORAGE_DRIVER=local
REQUIRE_HA=false
STORAGE_TEMP_ROOT=/tmp/backend-object-storage
OBJECT_STORAGE_ENDPOINT=
# URL HTTPS publica que corresponde a ${OBJECT_STORAGE_PREFIX}/uploads en el
# bucket/CDN. El backend agrega tenants/{tenant_id}/...; no contiene credenciales.
OBJECT_STORAGE_PUBLIC_BASE_URL=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_ACCESS_KEY_FILE=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_SECRET_KEY_FILE=
OBJECT_STORAGE_SESSION_TOKEN=
OBJECT_STORAGE_SESSION_TOKEN_FILE=
# Atestacion operativa obligatoria antes de migrar .p12/.pfx historicos. Solo
# activar tras verificar KMS, cifrado, versionado y retencion del bucket real.
OBJECT_STORAGE_PRIVATE_KMS_VERIFIED=false
OBJECT_STORAGE_PREFIX=paramascotasec
OBJECT_STORAGE_PATH_STYLE=true
OBJECT_STORAGE_TLS_VERIFY=true
OBJECT_STORAGE_TIMEOUT_SECONDS=15
# Solo production readiness/CronJob ejecuta el canary put-get-delete real.
OBJECT_STORAGE_CANARY_ENABLED=false

# Umbrales del check SLO reproducible. No sustituyen una plataforma de alertas;
# check_runtime_slo.sh devuelve exit 1 y lineas ALERT para cron/CI/monitoring.
SLO_REQUESTS=10
SLO_CONCURRENCY=2
SLO_MIN_SUCCESS_PERCENT=100
SLO_HEALTH_P95_MAX_SECONDS=1.0
SLO_CATALOG_P95_MAX_SECONDS=2.0
